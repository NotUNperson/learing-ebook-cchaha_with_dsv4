" ============================================================================
" .vimrc 示例 — 适合 Linux 初学者
" ============================================================================
" 将此文件复制到 ~/.vimrc 即可使用:
"   cp vimrc-example ~/.vimrc
"
" 在 Vim 中重新加载配置（无需重启 Vim）:
"   :source ~/.vimrc    或简写 :so ~/.vimrc
"
" 查看某个选项的当前值:
"   :set number?        查看行号是否开启
"   :set tabstop?       查看 tab 宽度
" ============================================================================

" ---- 基础设置 ----
set nocompatible              " 关闭 vi 兼容模式，启用 Vim 全部特性
set encoding=utf-8            " 内部编码使用 UTF-8
set fileencoding=utf-8        " 文件默认以 UTF-8 编码保存
set fileencodings=utf-8,gbk,gb2312,latin1  " 打开文件时尝试的编码顺序
set history=1000              " 记住 1000 条命令历史
set undofile                  " 持久化撤销（关闭文件后还能撤销）
set undodir=~/.vim/undo       " 撤销文件的存放目录
set autoread                  " 文件被外部程序修改时自动重新读取
set hidden                    " 允许切换缓冲区时不保存（不弹出警告）
set ttyfast                   " 告诉 Vim 终端连接很快（优化重绘）
set lazyredraw                " 执行宏时不刷新屏幕（加快宏执行）

" ---- 外观 ----
syntax on                     " 开启语法高亮
set number                    " 显示绝对行号
set relativenumber            " 显示相对行号（当前行为 0，方便用 5j 等跳转）
set cursorline                " 高亮当前行
set showcmd                   " 右下角显示正在输入的命令（如 3dw 中的 3）
set showmode                  " 左下角显示当前模式（-- INSERT -- 等）
set ruler                     " 右下角显示光标位置（行号,列号）
set laststatus=2              " 始终显示状态栏（值为 0 不显示, 1 多窗口才显示, 2 始终显示）
set scrolloff=5               " 光标距离屏幕顶部/底部至少保留 5 行
set sidescrolloff=5           " 光标距离屏幕左右边界至少保留 5 列
set wrap                      " 长行自动折行显示
set linebreak                 " 折行时尽量在单词边界处断开
set showmatch                 " 输入右括号时短暂跳转到匹配的左括号
set matchtime=2               " showmatch 的闪烁时间为 0.2 秒
set listchars=tab:>-,trail:~,extends:>,precedes:<  " 显示不可见字符时的样式
" set list                    " 取消注释以显示制表符和行尾空格（调试缩进时有用）

" ---- 缩进 ----
set autoindent                " 新行自动继承上一行的缩进
set smartindent               " 智能缩进（根据代码语法自动增减缩进级别）
set tabstop=4                 " Tab 键在屏幕上显示为 4 个空格的宽度
set shiftwidth=4              " >> 和 << 缩进时使用 4 个空格
set expandtab                 " 把 Tab 转换成空格（写 Python 必备）
set softtabstop=4             " 按 Tab 和 Backspace 时当作 4 个空格处理
set smarttab                  " 行首的 Tab 按 shiftwidth 缩进

" ---- 搜索 ----
set hlsearch                  " 搜索时高亮所有匹配结果
set incsearch                 " 增量搜索（边输入边跳转到匹配处）
set ignorecase                " 搜索时默认忽略大小写
set smartcase                 " 但如果搜索词包含大写字母，则自动区分大小写

" ---- 鼠标 ----
set mouse=a                   " 允许使用鼠标（点击定位光标、拖动分屏边界、滚轮滚动）
" 注意：在终端中使用鼠标时，按住 Shift 可以临时禁用鼠标行为
" （比如你想用鼠标选中文本复制到终端外）

" ---- 系统剪贴板 ----
" 让 Vim 的复制粘贴和系统剪贴板互通
" 需要 Vim 编译时开启了 +clipboard 支持
" 检查方法：vim --version | grep clipboard
set clipboard=unnamed         " 默认寄存器使用系统剪贴板
" 如果上面这行导致问题，可以改成只在复制时用系统剪贴板：
" set clipboard=unnamedplus   " Linux 上使用 + 寄存器作为默认

" ---- 退格键行为 ----
set backspace=indent,eol,start  " 允许退格键删除自动缩进、行尾换行符、进入 Insert 前的内容

" ---- 光标移动增强 ----
set whichwrap+=<,>,[,],h,l      " 允许光标在行首按 h 跳到上一行尾，在行尾按 l 跳到下一行首

" ---- 分屏行为 ----
set splitbelow                " 水平分屏时新窗口在下方
set splitright                " 垂直分屏时新窗口在右侧

" ---- Leader 键 ----
" Leader 键是自定义快捷键的"前缀"，默认为 \
" 把它改成空格键，更顺手
let mapleader = " "

" ---- 自定义快捷键 ----

" 用 leader+w 保存文件（替代 :w）
nnoremap <leader>w :w<CR>

" 用 leader+q 退出当前窗口（替代 :q）
nnoremap <leader>q :q<CR>

" 搜索后按 leader+/ 清除高亮
nnoremap <leader>/ :nohlsearch<CR>

" 用 Ctrl+hjkl 在分屏窗口间移动（替代 Ctrl+w h/j/k/l）
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" 用 jj 快速退出 Insert 模式（替代 Esc）
" 很多 Vim 用户的最爱——再也不用伸手够 Esc 了
inoremap jj <Esc>

" 在 Insert 模式下用 Ctrl+hjkl 移动光标（方向键的替代）
" 这样即使在输入文字时也能小范围移动光标
inoremap <C-h> <Left>
inoremap <C-j> <Down>
inoremap <C-k> <Up>
inoremap <C-l> <Right>

" 在 Visual 模式下用 J 和 K 上下移动选中的文本块
vnoremap J :m '>+1<CR>gv=gv
vnoremap K :m '<-2<CR>gv=gv

" leader+ev 快速打开并编辑 .vimrc
nnoremap <leader>ev :vsplit $MYVIMRC<CR>

" leader+sv 重新加载 .vimrc（source vimrc）
nnoremap <leader>sv :source $MYVIMRC<CR>

" 用 leader+y 复制到系统剪贴板（确保跨程序粘贴可用）
vnoremap <leader>y "+y

" leader+p 把当前行和下一行互换位置（mz 保存位置，ddp 交换，`z 恢复位置）
nnoremap <leader>p mzddp`z

" ---- 文件类型自动配置 ----
filetype plugin indent on     " 启用文件类型检测、文件类型插件、文件类型缩进

augroup my_filetype_settings
    autocmd!                  " 清除之前的自动命令，避免重复注册

    " Python: 4 空格缩进
    autocmd FileType python setlocal tabstop=4 shiftwidth=4 expandtab

    " JavaScript / TypeScript: 2 空格缩进
    autocmd FileType javascript,javascriptreact,typescript,typescriptreact setlocal tabstop=2 shiftwidth=2 expandtab

    " HTML / CSS: 2 空格缩进
    autocmd FileType html,css,scss setlocal tabstop=2 shiftwidth=2 expandtab

    " Makefile: 必须用真正的 Tab，不能用空格
    autocmd FileType make setlocal noexpandtab tabstop=8 shiftwidth=8

    " Markdown / 纯文本: 自动折行，开启拼写检查
    autocmd FileType markdown,text setlocal wrap linebreak spell

    " YAML: 2 空格缩进
    autocmd FileType yaml setlocal tabstop=2 shiftwidth=2 expandtab

    " Go: 真正的 Tab
    autocmd FileType go setlocal noexpandtab tabstop=4 shiftwidth=4
augroup END

" ---- 恢复上次文件打开时的光标位置 ----
" 打开文件时自动跳转到上次编辑的位置
augroup restore_cursor_position
    autocmd!
    autocmd BufReadPost *
        \ if line("'\"") >= 1 && line("'\"") <= line("$") |
        \   execute "normal! g`\"" |
        \ endif
augroup END

" ---- 自动删除行尾多余空格 ----
" 保存文件时自动删除行尾空格（某些语言如 Markdown 中行尾两个空格是有意义的，不予处理）
augroup trim_trailing_whitespace
    autocmd!
    autocmd BufWritePre *.{c,cpp,java,php,js,py,go,rs,sh,yml,yaml,toml,json,xml} :%s/\s\+$//e
augroup END

" ---- 插件管理（vim-plug）----
" 安装 vim-plug（只需执行一次）:
" curl -fLo ~/.vim/autoload/plug.vim --create-dirs \
"     https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
"
" 安装完 vim-plug 后，取消下面 call plug#begin ... call plug#end 的注释，
" 然后打开 Vim 执行 :PlugInstall

" call plug#begin('~/.vim/plugged')
"
" " 文件树浏览器
" " 用法: 按 <leader>n 切换文件树
" Plug 'preservim/nerdtree'
"
" " 模糊查找文件
" " 用法: 按 <leader>f 查找文件，<leader>b 切换缓冲区
" " 前提: 系统需要安装 fzf (brew install fzf / apt install fzf)
" Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }
" Plug 'junegunn/fzf.vim'
"
" " 状态栏美化
" Plug 'vim-airline/vim-airline'
"
" " 快速注释代码
" " 用法: gcc 注释/取消注释当前行，gc 在 Visual 模式注释选中行
" Plug 'tpope/vim-commentary'
"
" " 自动配对括号和引号
" Plug 'jiangmiao/auto-pairs'
"
" " Git 修改标记（在行号旁边显示 + - ~ 标记）
" Plug 'airblade/vim-gitgutter'
"
" " 颜色主题
" Plug 'morhetz/gruvbox'
"
" call plug#end()

" ---- 插件配置 ----
" 如果安装了对应插件，取消以下行的注释

" NERDTree 快捷键
" nnoremap <leader>n :NERDTreeToggle<CR>
" let NERDTreeShowHidden=1

" fzf 快捷键
" nnoremap <leader>f :Files<CR>
" nnoremap <leader>b :Buffers<CR>

" Gruvbox 主题
" colorscheme gruvbox
" set background=dark

" airline 配置
" let g:airline#extensions#tabline#enabled = 1   " 顶部显示标签页
" let g:airline_powerline_fonts = 1              " 使用 Powerline 字体（可选，需要先安装字体）

" ---- 颜色主题 (内置主题，不需要安装插件) ----
" 可以取消注释下面任意一行来使用 Vim 内置主题
" colorscheme desert     " 沙漠主题，暖色调，长时间看不累
" colorscheme elflord    " 深色主题
" colorscheme morning    " 浅色主题
" colorscheme pablo      " 高对比度深色主题
" colorscheme ron        " 深蓝底
" colorscheme torte      " 黑底

" ---- 状态栏格式 ----
" 如果不用 airline 插件，可以用内置的状态栏格式
set statusline=%F%m%r%h%w\ [%{&ff}]\ [%Y]\ [%l,%v]\ [%p%%]
" 状态栏从左到右显示:
"   %F    完整文件路径
"   %m    修改标记（[+] 有修改）
"   %r    只读标记
"   %h    帮助文件标记
"   %w    预览窗口标记
"   [%{&ff}] 文件格式（unix/dos/mac）
"   [%Y]  文件类型
"   [%l,%v] 行号,列号
"   [%p%%] 当前位置百分比

